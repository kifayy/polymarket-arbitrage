# Copy to .env and fill in real values. Never commit .env.
# cp .env.example .env

# =============================================================================
# Polymarket CLOB (required for live Polymarket orders)
# =============================================================================
# Wallet private key used to sign orders (hex, with or without 0x)
POLYMARKET_PRIVATE_KEY=YOUR_WALLET_PRIVATE_KEY_HERE

# Optional: pre-derived L2 API credentials (auto-derived from private key if empty)
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_PASSPHRASE=

# Proxy / deposit / Magic wallet address that holds funds (optional for EOA)
POLYMARKET_FUNDER_ADDRESS=0xYOUR_FUNDER_OR_PROXY_ADDRESS
# 0 = EOA, 1 = email/Magic, 2 = browser proxy wallet
POLYMARKET_SIGNATURE_TYPE=0

# Relayer (gasless) — optional, not used for CLOB order placement itself
POLYMARKET_RELAYER_API_KEY=
POLYMARKET_RELAYER_API_KEY_ADDRESS=

# =============================================================================
# Kalshi trading (required for live Kalshi orders)
# =============================================================================
KALSHI_API_KEY_ID=YOUR_KALSHI_API_KEY_ID_HERE

# Either paste the full PEM below OR point to a .pem file path
KALSHI_PRIVATE_KEY=
KALSHI_PRIVATE_KEY_PATH=secrets/kalshi_private_key.pem

# =============================================================================
# API-Football (required for soccer draw-bias bot)
# =============================================================================
API_FOOTBALL_KEY=YOUR_API_FOOTBALL_KEY_HERE

# =============================================================================
# Arb Desk UI lock (REQUIRED on Railway)
# Browser will prompt for these when you open the public URL
# =============================================================================
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=pick-a-long-random-password
